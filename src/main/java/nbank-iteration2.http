###

//Негативный кейс: Перевод между своими счетами, сумма null
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 2,
