Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 2,
  "amount": "100"
}
###

//Позитивный кейс: Перевод на чужой счет (AccoundId = 3 принадлежит пользователю Mary)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": 9999.99
}
###

//Позитивный кейс: Перевод на чужой счет (AccoundId = 3 принадлежит пользователю Mary)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": 10000
}
###

//Позитивный кейс: Перевод на чужой счет суммы 0.01
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": 0.01
}
###

//Негативный кейс: Перевод на чужой счет 0 (AccoundId = 3 принадлежит пользователю Mary)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": 0
}
###

//Негативный кейс: Перевод на чужой счет -0.01 (AccoundId = 3 принадлежит пользователю Mary)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": -0.01
}
###

//Негативный кейс: Перевод на чужой счет суммы больше 10_000 (AccoundId = 3 принадлежит пользователю Mary)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 3,
  "amount": 10000.01
}
###

//Негативный кейс: Перевод суммы превыщающей баланс (AccountId = 4, Id.balance = 0)
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 4,
  "receiverAccountId": 2,
  "amount": 100
}

### Изменение имени пользователя
//Позитивный кейс: Смена имени на два слова разделенные пробелом
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay Sysoev"
}
###

//Негативный кейс: Смена имени на одно слово
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay"
}

###
//Негативный кейс: Имя более 2х слов
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay Nikolay Nikolay"
}
###

//Негативный кейс: Имя пустое
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": ""
}
###
//Негативный кейс: Имя null
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": null
}
###

//Негативный кейс: Смена имени содержит цифры в имени
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay123 Sysoev"
}

###

//Негативный кейс: Смена имени содержит цифры в фамилии
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay Sysoev123"
}
###

//Негативный кейс: Смена имени содержит символы в имени
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay^&*(! Sysoev"
}

###

//Негативный кейс: Смена имени содержит символы в фамилии
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "Nikolay Sysoev^&*(!"
}
###

//Негативный кейс: Имя из цифр и символов
PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "name": "12312 ^&*(!"
