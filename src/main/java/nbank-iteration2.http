### Депозит на счет
//Позитивный кейс: Депозит на свой счет 4999.99 рублей
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": 4999.99
}
###

//Позитивный кейс: Депозит на свой счет 5000 рублей
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": 5000
}
###

//Позитивный кейс: Депозит на свой счет 0.01 рублей
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": 0.01
}
###

//Негативный кейс: Депозит на свой счет 5000.01 рублей - должен возвращать ошибку
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": 5000.01
}
###

//Негативный кейс: Депозит на свой счет 0 рублей
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": 0
}
###

//Негативный кейс: Депозит на свой счет отрицательной суммы
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": -0.01
}
###
//Негативный кейс: Депозит на свой счет null
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": null
}
###
//Негативный кейс: Депозит на свой счет числа обернутого в строку
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 1,
  "balance": "100"
}
###

//Негативный кейс: Депозит на чужой счет
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 3,
  "balance": 500
}
###

//Негативный кейс: Депозит на несуществующий счет
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "id": 9999999999,
  "balance": 500
}

### Перевод денег пользователем
//Позитивный кейс: Перевод между своими счетами
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 2,
  "amount": 9999.99
}
###

//Позитивный кейс: Перевод между своими счетами
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 2,
  "amount": 10000
}
###

//Позитивный кейс: Перевод между своими счетами
POST http://localhost:4111/api/v1/accounts/transfer
Content-Type: application/json
Authorization: Basic Tmlrb2xheTpOaWtvbGF5MTIzJFBhc3N3b3Jk

{
  "senderAccountId": 1,
  "receiverAccountId": 2,
  "amount": 0.01
}
###

//Негативный кейс: Перевод между своими счетами, сумма больше 10_000.01
POST http://localhost:4111/api/v1/accounts/transfer
